    "db:migrate": "drizzle-kit migrate",
    "db:clear": "tsx src/db/scripts/clear.ts",
    "db:push": "drizzle-kit push --force",
    "db:pull": "drizzle-kit pull",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/scripts/seed.ts",
    "db:reset-seed": "pnpm db:clear && pnpm db:push && pnpm db:seed",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "stripe:logs": "stripe logs tail",
    "init:env": "tsx scripts/init-env.ts",
    "knip": "knip"
  },
