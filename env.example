DATABASE_URL="postgres://username:password@host:port/database?sslmode=require"
AUTH_SECRET="your-auth-secret-key-here"
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM="admin@yourdomain.com"
EMAIL_TO="admin@yourdomain.com"
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_BUCKET=your-bucket-name
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_webhooksecrzet

BETTER_AUTH_SECRET="your-better-auth-secret-key-here"
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_REQUIRE_EMAIL_VERIFICATION=true
NEXT_PUBLIC_BETTER_AUTH_2FA_SKIP_VERIFICATION_ON_ENABLE=true